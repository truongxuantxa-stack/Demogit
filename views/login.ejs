<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Đăng nhập vào Hệ thống Xin Giấy Giới Thiệu Sinh Viên - Trường Đại học Xây Dựng Hà Nội">
    <title>Đăng Nhập - Hệ Thống HUCE</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <!-- Shared HUCE Stylesheet (chứa Google Fonts + Design Tokens) -->
    <link rel="stylesheet" href="/css/style.css">
</head>
<body style="margin:0; padding:0; background-color: var(--huce-bg);">

<div class="login-page">

    <!-- ===== LEFT: Ảnh minh họa trường HUCE ===== -->
    <div class="login-left">
        <img src="/images/huce_campus.png" alt="Trường Đại học Xây Dựng Hà Nội" class="login-bg-image">
        <div class="login-left-overlay"></div>
        <div class="login-left-content">
            <span class="system-label">Hệ thống hành chính sinh viên</span>
            <h1>Hệ thống<br>Xin Giấy Giới Thiệu<br>Sinh Viên</h1>
            <p class="slogan">Trường Đại học Xây Dựng Hà Nội &mdash; Cơ sở giáo dục đạt chuẩn kiểm định quốc tế</p>
        </div>
    </div>

    <!-- ===== RIGHT: Form đăng nhập ===== -->
    <div class="login-right">

        <!-- Logo + Tên trường -->
        <div class="text-center mb-2">
            <img src="/images/logo_truong.png" alt="HUCE Logo" class="login-logo">
        </div>
        <p class="login-system-name text-center">Hệ thống Xin Giấy Giới Thiệu Sinh Viên</p>

        <!-- Tiêu đề form -->
        <h2 class="login-form-title">Đăng nhập</h2>
        <p class="login-form-subtitle">Sử dụng tài khoản <strong>Cổng thông tin đào tạo</strong> (daotao.huce.edu.vn) để đăng nhập</p>

        <!-- Alerts -->
        <% if (error) { %>
            <div class="alert alert-danger d-flex align-items-center gap-2 py-2 mb-4" role="alert">
                <i class="bi bi-exclamation-circle-fill flex-shrink-0"></i>
                <span><%= error %></span>
            </div>
        <% } %>
        <% if (success) { %>
            <div class="alert alert-success d-flex align-items-center gap-2 py-2 mb-4" role="alert">
                <i class="bi bi-check-circle-fill flex-shrink-0"></i>
                <span><%= success %></span>
            </div>
        <% } %>

        <!-- Form -->
        <form action="/login" method="POST" id="loginForm" novalidate>
            <div class="mb-3">
                <label class="form-label" for="username">Tên đăng nhập</label>
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="bi bi-person"></i>
                    </span>
                    <input type="text"
                           id="username"
                           name="username"
                           class="form-control"
                           placeholder="Nhập tên đăng nhập"
                           required
                           autocomplete="username">
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label" for="password">Mật khẩu</label>
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="bi bi-lock"></i>
                    </span>
                    <input type="password"
                           id="password"
                           name="password"
                           class="form-control"
                           placeholder="Nhập mật khẩu"
                           required
                           autocomplete="current-password">
                    <button class="btn btn-outline-secondary border-start-0" type="button" id="togglePassword" tabindex="-1"
                            style="border-color: var(--huce-border); border-left: none; border-radius: 0 8px 8px 0;">
                        <i class="bi bi-eye" id="toggleIcon"></i>
                    </button>
                </div>
            </div>

            <button type="submit" class="btn-login" id="loginBtn">
                <i class="bi bi-box-arrow-in-right me-2"></i>Đăng Nhập
            </button>
        </form>

        <!-- Footer note -->
        <div class="login-support-box">
            <p class="login-support-title"><i class="bi bi-headset me-1"></i>Hỗ trợ kỹ thuật</p>
            <div class="login-support-contacts">
                <a href="tel:02438697004" class="login-support-item">
                    <i class="bi bi-telephone-fill"></i>
                    <span>02438.697.004</span>
                </a>
                <a href="mailto:ctsv@huce.edu.vn" class="login-support-item">
                    <i class="bi bi-envelope-fill"></i>
                    <span>ctsv@huce.edu.vn</span>
                </a>
            </div>
        </div>
        <p class="login-footer-note">© 2026 Trường Đại học Xây Dựng Hà Nội</p>
    </div>
</div>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    // Toggle hiển thị mật khẩu
    const toggleBtn = document.getElementById('togglePassword');
    const passwordInput = document.getElementById('password');
    const toggleIcon = document.getElementById('toggleIcon');

    toggleBtn.addEventListener('click', function() {
        const isPassword = passwordInput.type === 'password';
        passwordInput.type = isPassword ? 'text' : 'password';
        toggleIcon.className = isPassword ? 'bi bi-eye-slash' : 'bi bi-eye';
    });

    // Loading state khi submit
    document.getElementById('loginForm').addEventListener('submit', function() {
        const btn = document.getElementById('loginBtn');
        // Sử dụng setTimeout để đảm bảo form được trình duyệt gửi đi TRƯỚC khi nút bấm bị vô hiệu hóa
        setTimeout(() => {
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Đang đăng nhập...';
            btn.disabled = true;
        }, 0);
    });
</script>
</body>
</html>
