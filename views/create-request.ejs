<%- include('partials/header') %>

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-7">
        <div class="huce-card">
            <div class="huce-card-header">
                <h5>
                    <i class="bi bi-file-earmark-plus me-2" style="color: var(--huce-primary);"></i>
                    Tạo Yêu Cầu Giấy Giới Thiệu
                </h5>
            </div>
            <div class="p-4">
                <% if (error) { %>
                    <div class="alert alert-danger d-flex align-items-center gap-2 py-2 mb-4" role="alert">
                        <i class="bi bi-exclamation-circle-fill flex-shrink-0"></i>
                        <span><%= error %></span>
                    </div>
                <% } %>

                <form action="/requests" method="POST" novalidate>
                    <div class="mb-4">
                        <label class="form-label fw-semibold" for="requestType">
                            Loại giấy giới thiệu <span class="text-danger">*</span>
                        </label>
                        <select name="type" id="requestType" class="form-select" required>
                            <option value="">— Chọn loại giấy —</option>
                            <option value="Thực tập doanh nghiệp">Thực tập doanh nghiệp</option>
                            <option value="Liên hệ công tác">Liên hệ công tác</option>
                            <option value="Làm đề tài nghiên cứu">Làm đề tài nghiên cứu</option>
                        </select>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold" for="receiver">
                            Nơi nhận (Công ty / Cơ quan) <span class="text-danger">*</span>
                        </label>
                        <div class="input-group">
                            <span class="input-group-text" style="border-radius: 8px 0 0 8px;">
                                <i class="bi bi-building"></i>
                            </span>
                            <input type="text"
                                   name="receiver"
                                   id="receiver"
                                   class="form-control"
                                   style="border-radius: 0 8px 8px 0;"
                                   placeholder="VD: Công ty Cổ phần FPT"
                                   required>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold" for="requestContent">
                            Lý do / Mục đích xin giấy <span class="text-danger">*</span>
                        </label>
                        <textarea name="content"
                                  id="requestContent"
                                  class="form-control"
                                  rows="5"
                                  placeholder="Nhập nội dung cần giới thiệu..."
                                  required
                                  style="border-radius: 8px; resize: vertical;"></textarea>
                        <div class="form-text text-muted" style="font-size:0.78rem;">
                            <i class="bi bi-info-circle me-1"></i>Mô tả rõ ràng mục đích để được xét duyệt nhanh hơn.
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center pt-2 border-top">
                        <a href="/dashboard" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i>Quay lại
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-send me-1"></i>Gửi Yêu Cầu
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const typeSelect = document.getElementById('requestType');
        const contentTextarea = document.getElementById('requestContent');

        const placeholders = {
            'Thực tập doanh nghiệp': 'VD: Thực tập doanh nghiệp và thu thập số liệu làm đồ án khóa học...',
            'Liên hệ công tác': 'VD: Liên hệ công tác, quan sát và tìm hiểu quy trình làm việc thực tế tại cơ quan...',
            'Làm đề tài nghiên cứu': 'VD: Thu thập số liệu và tìm hiểu thực tế phục vụ đề tài nghiên cứu...'
        };

        typeSelect.addEventListener('change', function() {
            contentTextarea.placeholder = placeholders[this.value] || 'Nhập nội dung cần giới thiệu...';
        });
    });
</script>

<%- include('partials/footer') %>
