    <!-- ===== TOAST CONTAINER ===== -->
    <div class="toast-stack" id="toastStack"></div>

    <!-- ===== CONFIRM MODAL ===== -->
    <div class="modal fade" id="confirmModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content border-0 shadow">
                <div class="modal-header border-bottom-0 pb-0">
                    <h6 class="modal-title">
                        <i class="bi bi-exclamation-triangle-fill text-warning me-2"></i>
                        Xác nhận thao tác
                    </h6>
                </div>
                <div class="modal-body py-3">
                    <p id="confirmMessage" class="mb-0 text-center" style="font-size:0.9rem;"></p>
                </div>
                <div class="modal-footer border-top-0 pt-0 gap-2 justify-content-center">
                    <button type="button" class="btn btn-sm btn-secondary" id="confirmCancel" data-bs-dismiss="modal">Hủy</button>
                    <button type="button" class="btn btn-sm btn-primary" id="confirmOk">Xác nhận</button>
                </div>
