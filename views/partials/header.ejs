<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hệ Thống Xin Giấy Giới Thiệu - HUCE</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <!-- Shared HUCE Stylesheet -->
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <!-- ===== TOP HEADER BANNER (HTML Rebuild) ===== -->
    <div class="huce-top-banner bg-white border-bottom py-2 py-lg-3">
        <div class="container d-flex flex-column flex-lg-row justify-content-between align-items-center gap-3">
            <!-- Left: Logo & Title -->
            <a href="/" class="d-flex align-items-center text-decoration-none">
                <img src="/images/logo_truong.png" alt="HUCE Logo" style="height: 75px; width: auto; object-fit: contain;">
            </a>

            <!-- Right: Contact Info -->
            <div class="d-none d-lg-flex gap-4">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-telephone-fill" style="color: var(--huce-accent); font-size: 1.8rem; transform: scaleX(-1);"></i>
                    <div class="text-start">
                        <div style="color: var(--huce-primary); font-weight: 700; font-size: 0.85rem; line-height: 1.2;">Hotline</div>
                        <div style="color: var(--huce-text-muted); font-size: 0.85rem; font-weight: 500;">02438697004</div>
                    </div>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-envelope-fill" style="color: var(--huce-accent); font-size: 1.8rem;"></i>
                    <div class="text-start">
                        <div style="color: var(--huce-primary); font-weight: 700; font-size: 0.85rem; line-height: 1.2;">Email</div>
                        <div style="color: var(--huce-text-muted); font-size: 0.85rem; font-weight: 500;">ctsv@huce.edu.vn</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== NAVBAR ===== -->
    <nav class="huce-navbar navbar navbar-expand-lg">
        <div class="container">
            <!-- Mobile toggle -->
            <button class="navbar-toggler ms-auto me-2" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavCollapse">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Nav links + User profile -->
            <div class="collapse navbar-collapse" id="mainNavCollapse">
                <!-- Center nav links -->
                <ul class="navbar-nav me-auto gap-1" id="main-nav-tabs">
                    <% if (typeof user !== 'undefined' && user) { %>
                        <% if (user.role === 'admin') { %>
                            <li class="nav-item">
                                <a class="nav-link" href="/admin/dashboard">
                                    <i class="bi bi-list-check"></i> Quản lý yêu cầu
                                </a>
                            </li>
                        <% } else { %>
                            <li class="nav-item">
                                <a class="nav-link" href="/dashboard">
                                    <i class="bi bi-clock-history"></i> Lịch sử xin giấy
                                </a>
                            </li>
                        <% } %>
                    <% } else { %>
                        <li class="nav-item">
                            <a class="nav-link" href="/login">
                                <i class="bi bi-box-arrow-in-right"></i> Đăng nhập
                            </a>
                        </li>
                    <% } %>
                </ul>

                <!-- Right: User profile -->
                <% if (typeof user !== 'undefined' && user) { %>
                <div class="navbar-user ms-3 ps-3 border-start">
                    <img src="https://ui-avatars.com/api/?name=<%= encodeURIComponent(user.full_name) %>&background=103f91&color=fff&bold=true&size=72"
                         alt="Avatar" class="navbar-avatar flex-shrink-0">
                    <div class="navbar-user-info d-none d-lg-flex flex-column justify-content-center">
                        <p class="user-name"><%= user.full_name %></p>
                        <p class="user-role"><%= user.role === 'admin' ? 'Cán bộ hành chính' : `MSSV: ${user.username}` %></p>
                    </div>
                    <a href="/logout" class="btn-logout" title="Đăng xuất">
                        <i class="bi bi-power"></i>
                        <span class="d-none d-lg-inline">Thoát</span>
                    </a>
                </div>
                <% } %>
            </div>
        </div>
    </nav>

    <!-- ===== SUB-HEADER (Page Title + Breadcrumb) ===== -->
    <% if (typeof pageTitle !== 'undefined' && pageTitle) { %>
    <div class="page-subheader">
        <div class="container">
            <% if (typeof breadcrumb !== 'undefined' && breadcrumb && breadcrumb.length > 0) { %>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <% breadcrumb.forEach(function(item, index) { %>
                        <% if (item.href) { %>
                            <li class="breadcrumb-item"><a href="<%= item.href %>"><%= item.label %></a></li>
                        <% } else { %>
                            <li class="breadcrumb-item active" aria-current="page"><%= item.label %></li>
                        <% } %>
                    <% }); %>
                </ol>
            </nav>
            <% } %>
            <h1 class="page-title"><%= pageTitle %></h1>
        </div>
    </div>
    <% } %>

    <!-- Script set active nav link -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var currentPath = window.location.pathname;
            document.querySelectorAll('#main-nav-tabs .nav-link').forEach(function(link) {
                if (link.getAttribute('href') === currentPath) {
                    link.classList.add('active');
                }
            });
        });
    </script>

    <!-- ===== MAIN CONTENT ===== -->
    <div class="main-content">
        <div class="container">
