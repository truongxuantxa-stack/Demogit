<%- include('partials/header') %>

<!-- Modal Chi Tiết Yêu Cầu -->
<div class="modal fade" id="detailModal" tabindex="-1" aria-labelledby="detailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="huce-modal-header modal-header">
                <h5 class="modal-title" id="detailModalLabel">
                    <i class="bi bi-file-earmark-text me-2"></i>Chi Tiết Yêu Cầu
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-3">
                <div class="row g-3">
                    <!-- Thông tin giấy -->
                    <div class="col-12">
                        <p class="modal-section-title">
                            <i class="bi bi-journal-text me-2"></i>Thông Tin Giấy Giới Thiệu
                        </p>
                        <div class="row g-2">
                            <div class="col-sm-6">
                                <p class="detail-label">Mã yêu cầu</p>
                                <p class="detail-value" id="detail-id">—</p>
                            </div>
                            <div class="col-sm-6">
                                <p class="detail-label">Loại giấy</p>
                                <p class="detail-value" id="detail-type">—</p>
                            </div>
                            <div class="col-sm-6">
                                <p class="detail-label">Nơi nhận</p>
                                <p class="detail-value" id="detail-receiver">—</p>
                            </div>
                            <div class="col-sm-6">
                                <p class="detail-label">Ngày tạo</p>
                                <p class="detail-value" id="detail-created-at">—</p>
                            </div>
                        </div>
                    </div>

                    <!-- Lý do -->
                    <div class="col-12">
                        <p class="modal-section-title">
                            <i class="bi bi-chat-left-text me-2"></i>Lý Do / Mục Đích
                        </p>
                        <div class="detail-content-box" id="detail-content">—</div>
                    </div>

                    <!-- Trạng thái -->
                    <div class="col-12">
                        <p class="detail-label mb-2">Trạng thái hiện tại</p>
                        <span id="detail-status-badge">—</span>
                        <div id="detail-pdf-link" class="mt-3 d-none">
                            <a id="detail-pdf-url" href="#" target="_blank" class="btn btn-sm btn-outline-success">
                                <i class="bi bi-file-earmark-pdf me-1"></i>Tải file PDF
                            </a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer bg-light border-top">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>

<!-- Bảng dữ liệu -->
<div class="huce-card">
    <div class="huce-card-header">
        <h5><i class="bi bi-clock-history me-2" style="color: var(--huce-primary);"></i>Giấy giới thiệu của tôi</h5>
        <a href="/create-request" class="btn btn-primary btn-sm">
            <i class="bi bi-file-earmark-plus me-1"></i>Tạo yêu cầu mới
        </a>
    </div>

    <% if (requests.length === 0) { %>
        <div class="empty-state">
            <i class="bi bi-inbox"></i>
            <p>Bạn chưa có yêu cầu nào.</p>
            <a href="/create-request" class="btn btn-primary btn-sm mt-3">
                <i class="bi bi-file-earmark-plus me-1"></i>Tạo yêu cầu đầu tiên
            </a>
        </div>
    <% } else { %>
        <div class="table-responsive">
            <table class="table huce-table mb-0">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Loại giấy</th>
                        <th>Nơi nhận</th>
                        <th>Ngày tạo</th>
                        <th>Trạng thái</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    <% requests.forEach(function(req) { %>
                        <tr>
                            <td>
                                <span style="font-size:0.8rem; color: var(--huce-text-muted); font-weight:600;">#<%= req.id %></span>
                            </td>
                            <td><%= req.type %></td>
                            <td style="max-width: 160px;">
                                <span class="d-inline-block text-truncate" style="max-width: 140px;" title="<%= req.receiver %>">
                                    <%= req.receiver %>
                                </span>
                            </td>
                            <td><%= new Date(req.created_at).toLocaleDateString('vi-VN') %></td>
                            <td>
                                <% if (req.status === 'pending') { %>
                                    <span class="badge-pending">Chờ duyệt</span>
                                <% } else if (req.status === 'approved') { %>
                                    <span class="badge-approved">Đã duyệt</span>
                                <% } else { %>
                                    <span class="badge-rejected">Từ chối</span>
                                <% } %>
                            </td>
                            <td>
                                <div class="d-flex gap-1 align-items-center">
                                    <!-- Nút Xem Chi Tiết -->
                                    <button class="btn-action-icon btn-detail"
                                        title="Xem chi tiết"
                                        style="color:#0891b2; border-color:#0891b2;"
                                        data-id="<%= req.id %>"
                                        data-type="<%= req.type %>"
                                        data-receiver="<%= req.receiver %>"
                                        data-content="<%= req.content %>"
                                        data-created-at="<%= new Date(req.created_at).toLocaleDateString('vi-VN') %>"
                                        data-status="<%= req.status %>"
                                        data-pdf-url="<%= req.pdf_url || '' %>">
                                        <i class="bi bi-eye"></i>
                                    </button>

                                    <!-- Nút Tải PDF nếu đã duyệt -->
                                    <% if (req.status === 'approved' && req.pdf_url) { %>
                                        <a href="<%= req.pdf_url %>" class="btn-action-icon" target="_blank"
                                           title="Tải PDF"
                                           style="color:#059669; border-color:#059669;">
                                            <i class="bi bi-file-earmark-pdf"></i>
                                        </a>
                                    <% } %>
                                </div>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    <% } %>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const detailModal = new bootstrap.Modal(document.getElementById('detailModal'));

        document.querySelectorAll('.btn-detail').forEach(btn => {
            btn.addEventListener('click', () => {
                document.getElementById('detail-id').textContent = '#' + btn.dataset.id;
                document.getElementById('detail-type').textContent = btn.dataset.type;
                document.getElementById('detail-receiver').textContent = btn.dataset.receiver;
                document.getElementById('detail-content').textContent = btn.dataset.content || '(Không có nội dung)';
                document.getElementById('detail-created-at').textContent = btn.dataset.createdAt;

                const status = btn.dataset.status;
                const badgeMap = {
                    pending:  '<span class="badge-pending">Chờ duyệt</span>',
                    approved: '<span class="badge-approved">Đã duyệt</span>',
                    rejected: '<span class="badge-rejected">Từ chối</span>'
                };
                document.getElementById('detail-status-badge').innerHTML = badgeMap[status] || status;

                const pdfLink = document.getElementById('detail-pdf-link');
                const pdfUrl = btn.dataset.pdfUrl;
                if (status === 'approved' && pdfUrl) {
                    document.getElementById('detail-pdf-url').href = pdfUrl;
                    pdfLink.classList.remove('d-none');
                } else {
                    pdfLink.classList.add('d-none');
                }

                detailModal.show();
            });
        });
    });
</script>

<%- include('partials/footer') %>
