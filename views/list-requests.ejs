<%- include('partials/header') %>

<div class="row mt-4">
    <div class="col-md-12">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h3>Danh Sách Giấy Giới Thiệu Của Tôi</h3>
            <a href="/create-request" class="btn btn-primary">Tạo yêu cầu mới</a>
        </div>

        <div class="card shadow-sm">
            <div class="card-body">
                <% if (requests.length === 0) { %>
                    <p class="text-center text-muted my-4">Bạn chưa có yêu cầu nào.</p>
                <% } else { %>
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Loại giấy</th>
                                <th>Nơi nhận</th>
                                <th>Ngày tạo</th>
                                <th>Trạng thái</th>
                                <th>Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% requests.forEach(function(req) { %>
                                <tr>
                                    <td>#<%= req.id %></td>
                                    <td><%= req.type %></td>
                                    <td><%= req.receiver %></td>
                                    <td><%= new Date(req.created_at).toLocaleDateString('vi-VN') %></td>
                                    <td>
                                        <% if (req.status === 'pending') { %>
                                            <span class="badge bg-warning text-dark">Chờ duyệt</span>
                                        <% } else if (req.status === 'approved') { %>
                                            <span class="badge bg-success">Đã duyệt</span>
                                        <% } else { %>
                                            <span class="badge bg-danger">Từ chối</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <% if (req.status === 'approved' && req.pdf_url) { %>
                                            <a href="<%= req.pdf_url %>" class="btn btn-sm btn-outline-success" target="_blank">Tải PDF</a>
                                        <% } else { %>
                                            <span class="text-muted">-</span>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                <% } %>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
